# ----------------------------------------
# file: $HOME/.dir_colors
# vim:fenc=utf-8:nu:ai:si:et:ts=4:sw=4:
# ----------------------------------------
# Palette: cold dark (synced with nvim/kitty)
#   tan     #D0A080 = 208;160;128
#   keyword #DB8858 = 219;136;88
#   diff_fg #50A8B8 = 80;168;184
#   comment #82849E = 130;132;158
#   yellow  #E8B855 = 232;184;85
#   blue    #8898C8 = 136;152;200
#   border  #967F8E = 150;127;142
#   red     #D86060 = 216;96;96
#   fg      #ECE0D0 = 236;224;208

COLOR all
OPTIONS -F -b -T 0
EIGHTBIT 1

# file types — truecolor (38;2;R;G;B)
NORMAL             00;38;2;150;127;142        # border
FILE               00;38;2;208;160;128        # tan
DIR                01;38;2;232;184;85         # yellow (bold)
LINK               01;38;2;80;168;184         # diff_fg (bold)
FIFO               03;38;2;80;168;184         # diff_fg (italic)
SOCK               03;38;2;80;168;184         # diff_fg (italic)
BLK                03;38;2;150;127;142        # border (italic)
CHR                03;38;2;150;127;142        # border (italic)
ORPHAN             04;38;2;216;96;96          # red (underline)
STICKY_OTHER_WRITABLE 01;38;2;236;224;208     # fg (bold)
OTHER_WRITABLE     38;2;150;127;142           # border
STICKY             01;38;2;236;224;208        # fg (bold)

EXEC               00;38;2;236;224;208        # fg
.cmd               00;38;2;236;224;208
.exe               00;38;2;236;224;208
.com               00;38;2;236;224;208
.btm               00;38;2;236;224;208
