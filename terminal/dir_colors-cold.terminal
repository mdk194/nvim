.webp              38;2;130;132;158
.ico               38;2;130;132;158
.avif              38;2;130;132;158

.mp3               38;2;150;127;142           # border
.flac              38;2;150;127;142
.mid               38;2;150;127;142
.wav               38;2;150;127;142
.au                38;2;150;127;142
