.rar               03;01;38;2;232;184;85
.zst               03;01;38;2;232;184;85
.7z                03;01;38;2;232;184;85

.pdf               38;2;130;132;158           # comment
.jpg               38;2;130;132;158
.gif               38;2;130;132;158
