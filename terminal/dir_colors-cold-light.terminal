# ----------------------------------------
# file: $HOME/.dir_colors
# vim:fenc=utf-8:nu:ai:si:et:ts=4:sw=4:
# ----------------------------------------
# Palette: cold-light (synced with nvim/kitty)
#   tan     #785438 = 120;84;56
#   keyword #8D4A1B = 141;74;27
#   diff_fg #206284 = 32;98;132
#   comment #5E5871 = 94;88;113
#   yellow  #6E5A15 = 110;90;21
#   blue    #4550B0 = 69;80;176
#   border  #665767 = 102;87;103
#   red     #9C3C3C = 156;60;60
#   fg      #1C1828 = 28;24;40

COLOR all
OPTIONS -F -b -T 0
EIGHTBIT 1

# file types — truecolor (38;2;R;G;B)
NORMAL             00;38;2;102;87;103        # border
FILE               00;38;2;120;84;56          # tan
DIR                01;38;2;110;90;21         # yellow (bold)
