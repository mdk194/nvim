CHR                03;38;2;102;87;103        # border (italic)
ORPHAN             04;38;2;156;60;60          # red (underline)
STICKY_OTHER_WRITABLE 01;38;2;28;24;40        # fg (bold)
OTHER_WRITABLE     38;2;102;87;103           # border
